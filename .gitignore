# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (root and all workspaces)
/node_modules
**/node_modules
**/node_modules/**
/.pnp
.pnpm
**/.pnpm
**/.pnpm/**
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js (all workspaces)
.next/
out/
**/.next/
**/out/
*.tsbuildinfo

# build / cache
dist/
**/dist/
.turbo
.cache

# cms / database
*.db
**/*.db
*.sqlite
**/*.sqlite
apps/cms/data/
apps/cms/media/
cms/.next/
cms/out/
cms/media/
**/importMap.js

# production
/build
/docs
# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
next-env.d.ts

# ide / tooling
.agents
.cursor
.turbo
.pnpm-store

# locally-hosted fonts (converted from downloads, not committed as binaries)
apps/web/public/fonts/noto-serif/*.woff2
apps/web/public/fonts/manrope/*.woff2

# lockfiles (optional: uncomment to ignore)
# pnpm-lock.yaml
