# Public site (apps/web)
# CMS API base URL; in dev, web falls back to http://localhost:3001 if unset
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3001

# Optional: site URL for redirects (e.g. admin route)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: social links (hero and home sidebar; omit to hide)
# NEXT_PUBLIC_GITHUB_URL=https://github.com/yourusername
# NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com/in/yourusername
# NEXT_PUBLIC_TWITTER_URL=https://x.com/yourusername

# Optional: Supabase (if using Supabase features in web)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: GitHub (if using GitHub API in web)
# GITHUB_USERNAME=
# GITHUB_TOKEN=

# CMS (apps/cms) — create apps/cms/.env.local for CMS-specific vars
# PAYLOAD_SECRET=            # Required for Payload; use a long random string
# PAYLOAD_PUBLIC_SERVER_URL= # e.g. http://localhost:3001
# OPENAI_API_KEY=            # Optional; for TTS or other CMS features
# CMS_DB_PATH=               # Optional; path to SQLite DB file


#POSTGRES
#DATABASE_URL=postgresql://username:your-password@localhost:5432/db_name