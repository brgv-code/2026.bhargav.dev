{
  "name": "2026.bhargav.dev",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@repo/web",
    "dev:cms": "turbo run dev --filter=@repo/cms",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@repo/web",
    "build:cms": "turbo run build --filter=@repo/cms",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@alloc/quick-lru": "^5",
    "prettier": "^3",
    "turbo": "^2.0.0",
    "typescript": "^5"
  }
}
